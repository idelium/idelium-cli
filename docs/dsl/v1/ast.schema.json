{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/idelium/idelium-cli/raw/main/docs/dsl/v1/ast.schema.json",
  "title": "Idelium DSL v1 Canonical AST",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "languageVersion", "tests"],
  "properties": {
    "kind": {"const": "document"},
    "schemaVersion": {"const": "1.0"},
    "languageVersion": {"const": "1.0"},
    "sourceName": {"type": "string", "minLength": 1, "maxLength": 255},
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/test"}
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": {"type": "integer", "minimum": 1},
        "column": {"type": "integer", "minimum": 1}
      }
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"$ref": "#/$defs/position"},
        "end": {"$ref": "#/$defs/position"}
      }
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "value"],
      "properties": {
        "strategy": {"enum": ["css", "xpath"]},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "statements", "span"],
      "properties": {
        "kind": {"const": "test"},
        "name": {"type": "string", "minLength": 1},
        "statements": {
          "type": "array",
          "items": {"$ref": "#/$defs/statement"}
        },
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "statement": {
      "oneOf": [
        {"$ref": "#/$defs/open"},
        {"$ref": "#/$defs/click"},
        {"$ref": "#/$defs/write"},
        {"$ref": "#/$defs/wait"},
        {"$ref": "#/$defs/assertVisibility"},
        {"$ref": "#/$defs/assertText"},
        {"$ref": "#/$defs/back"},
        {"$ref": "#/$defs/forward"},
        {"$ref": "#/$defs/screenshot"}
      ]
    },
    "open": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "url", "span"],
      "properties": {
        "kind": {"const": "open"},
        "url": {"type": "string", "format": "uri", "pattern": "^https?://"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "click": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "locator", "span"],
      "properties": {
        "kind": {"const": "click"},
        "locator": {"$ref": "#/$defs/locator"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "write": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "locator", "value", "sensitive", "span"],
      "properties": {
        "kind": {"const": "write"},
        "locator": {"$ref": "#/$defs/locator"},
        "value": {"type": "string"},
        "sensitive": {"type": "boolean"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "wait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "locator", "condition", "span"],
      "properties": {
        "kind": {"const": "wait"},
        "locator": {"$ref": "#/$defs/locator"},
        "condition": {"enum": ["present", "visible", "hidden", "clickable"]},
        "timeoutMilliseconds": {"type": "integer", "minimum": 1},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "assertVisibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "locator", "expected", "span"],
      "properties": {
        "kind": {"const": "assertVisibility"},
        "locator": {"$ref": "#/$defs/locator"},
        "expected": {"enum": ["visible", "hidden"]},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "assertText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "locator",
        "comparison",
        "expected",
        "sensitive",
        "span"
      ],
      "properties": {
        "kind": {"const": "assertText"},
        "locator": {"$ref": "#/$defs/locator"},
        "comparison": {"enum": ["equals", "contains"]},
        "expected": {"type": "string"},
        "sensitive": {"type": "boolean"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "back": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "span"],
      "properties": {
        "kind": {"const": "back"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "forward": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "span"],
      "properties": {
        "kind": {"const": "forward"},
        "span": {"$ref": "#/$defs/span"}
      }
    },
    "screenshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "span"],
      "properties": {
        "kind": {"const": "screenshot"},
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!.*\\.\\.)[A-Za-z0-9._-]+$"
        },
        "span": {"$ref": "#/$defs/span"}
      }
    }
  }
}

